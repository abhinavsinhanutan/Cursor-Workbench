# Worksheet: Tableau env vars for your *local* mcp.json (DO NOT commit filled values)
#
# 1) Copy this file to e.g. config/.env on your machine, fill in, and keep
#    config/.env out of git (or use a password manager and paste once).
# 2) Transcribe the same key/value pairs into the "env" object for the
#    "tableau" entry in your private ~/.cursor/mcp.json or .cursor/mcp.json.
# 3) This repo only tracks .env.example — see MCP.md and mcp.json.example.

# Tableau Server / Cloud base URL (HTTPS, no trailing slash required per your server)
TABLEAU_SERVER_URL=https://your-tableau.example.com

# Usually empty for default site; your admin may give a "site content URL" slug
TABLEAU_SITE_CONTENT_URL=

# As shown in Tableau: Personal Access Tokens (create a new PAT, copy name + secret once)
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=REPLACE_PASTE_SECRET_FROM_TABLEAU_UI
