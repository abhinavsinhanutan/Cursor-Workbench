---
const site = Astro.site ?? new URL('https://abhinavsinhanutan.github.io');
const home = new URL(import.meta.env.BASE_URL, site).href;
---
<header class="site-header">
  <div class="wrap">
    <a class="logo" href={home}>Cursor-Workbench</a>
    <a class="nav-gh" href="https://github.com/abhinavsinhanutan/Cursor-Workbench" rel="noopener"
      >GitHub</a
    >
  </div>
</header>
