---
import Stats from './Stats.astro';
---
<div class="hero">
  <div class="wrap">
    <p class="hero-badge">Open kit · MIT · no global install</p>
    <h1>We gave your team a <span class="gradient">folder-shaped map</span> for Cursor.</h1>
    <p class="lead">
      Rules, skills, subagents, MCP examples, and hooks you can copy into
      <code style="color: var(--accent2)">.cursor/</code> — without pasting the same prompts
      from scratch every week.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="https://github.com/abhinavsinhanutan/Cursor-Workbench"
        >View on GitHub</a
      >
      <a
        class="btn btn-ghost"
        href="https://github.com/abhinavsinhanutan/Cursor-Workbench#readme">Read the README</a
      >
    </div>
    <Stats />
  </div>
</div>
