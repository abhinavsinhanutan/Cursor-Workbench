---
---
<section class="get-started" aria-labelledby="h-cta">
  <div class="wrap">
    <div class="cta-block">
      <h2 id="h-cta" style="margin:0 0 0.5rem;font-size:1.35rem">Get the kit</h2>
      <p class="section-lead" style="margin:0 auto 1rem">
        Clone, then follow the
        <a
          href="https://github.com/abhinavsinhanutan/Cursor-Workbench/blob/main/docs/SETUP.md"
          >install guide (SETUP.md)</a
        > in the repository.
      </p>
      <div class="code-row">
        <pre class="code-box" id="clone-snippet">git clone https://github.com/abhinavsinhanutan/Cursor-Workbench.git
cd Cursor-Workbench
export CURSOR_WB_ROOT="$(pwd)"</pre>
      </div>
      <button
        type="button"
        class="btn btn-ghost"
        id="btn-copy"
        style="margin-top:0.75rem"
        data-copy="clone-snippet"
        aria-label="Copy clone command to clipboard">Copy clone block</button
      >
      <p class="copy-ok" id="copy-status" role="status" aria-live="polite"></p>
    </div>
  </div>
</section>
