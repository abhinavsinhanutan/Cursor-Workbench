# Copy this file to `.env` and fill in your real Langfuse credentials.
#   cp .env.example .env
#
# Get your keys from:
#   Langfuse Cloud:  https://cloud.langfuse.com  ->  Settings -> API Keys
#   Self-hosted:     <your-langfuse-host>/project/<id>/settings

LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# US cloud is the default. Swap for the EU region or your self-hosted URL:
#   EU cloud:    https://cloud.langfuse.com
#   Self-hosted: http://your-langfuse-host:3000
LANGFUSE_HOST=https://us.cloud.langfuse.com
